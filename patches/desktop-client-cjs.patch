--- /dev/null
+++ b/apps/desktop/electron/desktop-mode.test.cjs
@@ -0,0 +1,19 @@
+'use strict'
+
+const test = require('node:test')
+const assert = require('node:assert/strict')
+
+const {
+  DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+  DEFAULT_REMOTE_CLIENT_URL,
+  DESKTOP_MODE
+} = require('./desktop-mode.cjs')
+
+test('desktop mode is an immutable remote-only client', () => {
+  assert.deepEqual(DESKTOP_MODE, {
+    defaultAuthMode: DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+    defaultRemoteUrl: DEFAULT_REMOTE_CLIENT_URL,
+    remoteOnly: true
+  })
+  assert.equal(Object.isFrozen(DESKTOP_MODE), true)
+})
