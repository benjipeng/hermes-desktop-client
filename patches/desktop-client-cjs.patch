diff --git a/apps/desktop/electron/desktop-mode.cjs b/apps/desktop/electron/desktop-mode.cjs
new file mode 100644
index 0000000..72e50d1
--- /dev/null
+++ b/apps/desktop/electron/desktop-mode.cjs
@@ -0,0 +1,19 @@
+'use strict'
+
+const DEFAULT_REMOTE_CLIENT_URL = 'http://127.0.0.1:9119'
+const DEFAULT_REMOTE_CLIENT_AUTH_MODE = 'oauth'
+
+// This source tree is used only to package the dedicated desktop client. The
+// upstream Hermes renderer stays intact, while the Python backend is supplied
+// by a separately managed gateway.
+const DESKTOP_MODE = Object.freeze({
+  defaultAuthMode: DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+  defaultRemoteUrl: DEFAULT_REMOTE_CLIENT_URL,
+  remoteOnly: true
+})
+
+module.exports = {
+  DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+  DEFAULT_REMOTE_CLIENT_URL,
+  DESKTOP_MODE
+}
diff --git a/apps/desktop/electron/desktop-mode.test.cjs b/apps/desktop/electron/desktop-mode.test.cjs
new file mode 100644
