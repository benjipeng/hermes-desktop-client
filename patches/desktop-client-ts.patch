@@ -0,0 +1,21 @@
+export type DesktopAuthMode = 'oauth' | 'token'
+
+export interface DesktopMode {
+  defaultAuthMode: DesktopAuthMode
+  defaultRemoteUrl: string
+  remoteOnly: boolean
+}
+
+export const DEFAULT_REMOTE_CLIENT_URL = 'http://127.0.0.1:9119'
+export const DEFAULT_REMOTE_CLIENT_AUTH_MODE: DesktopAuthMode = 'oauth'
+
+// This branch is the dedicated desktop-client distribution. The renderer is
+// the upstream Hermes desktop UI, while the Python backend is always supplied
+// by a separately managed gateway. Keeping the flavor in one immutable module
+// avoids package.json forks, runtime environment switches, and accidental
+// fallback to the local bootstrap path.
+export const DESKTOP_MODE: Readonly<DesktopMode> = Object.freeze({
+  defaultAuthMode: DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+  defaultRemoteUrl: DEFAULT_REMOTE_CLIENT_URL,
+  remoteOnly: true
+})
