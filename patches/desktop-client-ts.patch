--- /dev/null
+++ b/apps/desktop/electron/desktop-mode.test.ts
@@ -0,0 +1,18 @@
+import { describe, expect, it } from 'vitest'
+
+import {
+  DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+  DEFAULT_REMOTE_CLIENT_URL,
+  DESKTOP_MODE
+} from './desktop-mode'
+
+describe('desktop mode', () => {
+  it('defines an immutable remote-only desktop client', () => {
+    expect(DESKTOP_MODE).toEqual({
+      defaultAuthMode: DEFAULT_REMOTE_CLIENT_AUTH_MODE,
+      defaultRemoteUrl: DEFAULT_REMOTE_CLIENT_URL,
+      remoteOnly: true
+    })
+    expect(Object.isFrozen(DESKTOP_MODE)).toBe(true)
+  })
+})
